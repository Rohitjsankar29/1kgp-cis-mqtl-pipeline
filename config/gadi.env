# Edit these paths on Gadi/NCI before running
export PROJECT=cy94
export PIPELINE_DIR=${PIPELINE_DIR:-$PWD}
export GDATA_ROOT=${GDATA_ROOT:-/g/data/cy94/$USER/1kgp-cis-mqtl}
export SCRATCH_ROOT=${SCRATCH_ROOT:-/scratch/cy94/$USER/1kgp-cis-mqtl}
export REFERENCE=${REFERENCE:-/g/data/cy94/reference/hg38.fa}
export AWS=${AWS:-aws}
export MODKIT=${MODKIT:-modkit}

mkdir -p "$GDATA_ROOT" "$SCRATCH_ROOT" "$SCRATCH_ROOT/logs"
